# Which LACOP profile this deployment renders.
# Must match a row in src/data/mock.ts (today) or public_profiles.slug
# (when wired to Supabase). One codebase, many customer deployments — only
# these env values differ between them.
LACOP_USER_SLUG=hanna-burgstaller

# Public site origin — sets metadataBase, canonical, OG/Twitter URLs,
# sitemap + robots. Vercel fills this automatically from the production
# domain; set it locally if you test absolute URLs.
NEXT_PUBLIC_SITE_URL=https://hanna-burgstaller.lacop.site

# Supabase credentials — leave empty while this site uses the mock backend.
# Populate and swap the bodies in src/lib/lacop.ts for real queries to
# migrate this portfolio onto the live data (see § 11.1 of the spec).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
